<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stopwatch</title>
<link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet">
<style>
  :root, [data-theme="light"] {
    --color-bg: #f7f6f2; --color-surface: #f9f8f5; --color-surface-offset: #f3f0ec;
    --color-border: #d4d1ca; --color-divider: #dcd9d5;
    --color-text: #28251d; --color-text-muted: #7a7974; --color-text-faint: #bab9b4;
    --color-primary: #01696f; --color-primary-hover: #0c4e54;
    --color-error: #a12c7b; --color-success: #437a22; --color-warning: #964219;
    --shadow-md: 0 4px 12px oklch(0.2 0.01 80 / 0.08);
    --radius-md: 0.5rem; --radius-lg: 0.75rem; --radius-xl: 1rem; --radius-full: 9999px;
    --space-1:.25rem; --space-2:.5rem; --space-3:.75rem; --space-4:1rem;
    --space-5:1.25rem; --space-6:1.5rem; --space-8:2rem;
    --t: 180ms cubic-bezier(0.16,1,0.3,1);
    --font: 'Satoshi', system-ui, sans-serif;
  }
  [data-theme="dark"] {
    --color-bg: #171614; --color-surface: #1c1b19; --color-surface-offset: #1d1c1a;
    --color-border: #393836; --color-divider: #262523;
    --color-text: #cdccca; --color-text-muted: #797876; --color-text-faint: #5a5957;
    --color-primary: #4f98a3; --color-primary-hover: #227f8b;
    --color-error: #d163a7; --color-success: #6daa45; --color-warning: #bb653b;
    --shadow-md: 0 4px 12px oklch(0 0 0 / 0.3);
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) {
      --color-bg: #171614; --color-surface: #1c1b19; --color-surface-offset: #1d1c1a;
      --color-border: #393836; --color-divider: #262523;
      --color-text: #cdccca; --color-text-muted: #797876; --color-text-faint: #5a5957;
      --color-primary: #4f98a3; --color-primary-hover: #227f8b;
      --color-error: #d163a7; --color-success: #6daa45; --color-warning: #bb653b;
      --shadow-md: 0 4px 12px oklch(0 0 0 / 0.3);
    }
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-font-smoothing: antialiased; }
  body {
    min-height: 100dvh; font-family: var(--font); font-size: 1rem;
    background: var(--color-bg); color: var(--color-text);
    display: flex; align-items: center; justify-content: center;
    padding: var(--space-4); transition: background var(--t), color var(--t);
  }
  button { cursor: pointer; border: none; background: none; font: inherit; color: inherit; }
  .card {
    background: var(--color-surface);
    border: 1px solid oklch(from var(--color-text) l c h / 0.08);
    border-radius: var(--radius-xl); box-shadow: var(--shadow-md);
    padding: var(--space-6) var(--space-8);
    width: 100%; max-width: 320px;
    display: flex; flex-direction: column; gap: var(--space-5);
  }
  .header { display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: var(--space-2); font-size: .8125rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: .03em; }
  .logo svg { color: var(--color-primary); flex-shrink: 0; }
  .theme-btn { width:32px; height:32px; border-radius: var(--radius-full); display:flex; align-items:center; justify-content:center; color: var(--color-text-muted); transition: background var(--t), color var(--t); }
  .theme-btn:hover { background: var(--color-surface-offset); color: var(--color-text); }
  .display-wrap { text-align: center; padding: var(--space-4) 0 var(--space-1); }
  .time-main { font-size: clamp(3rem,12vw,4rem); font-weight: 700; letter-spacing: -.03em; font-variant-numeric: tabular-nums; color: var(--color-text); line-height: 1; transition: color var(--t); }
  .time-main.running { color: var(--color-primary); }
  .time-ms { font-size: clamp(1.1rem,4vw,1.35rem); font-weight: 500; color: var(--color-text-muted); font-variant-numeric: tabular-nums; margin-top: var(--space-1); }
  .status { font-size: .75rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--color-text-faint); margin-top: var(--space-3); }
  .status.running { color: var(--color-primary); }
  .status.paused { color: var(--color-warning); }
  .controls { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-2); }
  .btn { padding: .6rem .5rem; border-radius: var(--radius-lg); font-size: .875rem; font-weight: 600; text-align: center; transition: background var(--t), color var(--t), border-color var(--t); border: 1px solid transparent; }
  .btn-start { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .btn-start:hover { background: var(--color-primary-hover); border-color: var(--color-primary-hover); }
  .btn-stop { background: transparent; color: var(--color-error); border-color: oklch(from var(--color-error) l c h / 0.3); }
  .btn-stop:hover { background: oklch(from var(--color-error) l c h / 0.08); }
  .btn-lap { background: var(--color-surface-offset); color: var(--color-text-muted); border-color: var(--color-border); }
  .btn-lap:hover { background: var(--color-divider); color: var(--color-text); }
  .btn:disabled { opacity: .3; cursor: not-allowed; pointer-events: none; }
  .laps-section { border-top: 1px solid var(--color-divider); padding-top: var(--space-4); display: none; }
  .laps-section.on { display: block; }
  .laps-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-3); }
  .laps-title { font-size: .75rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--color-text-faint); }
  .clear-btn { font-size: .75rem; color: var(--color-text-faint); text-decoration: underline; text-underline-offset: 2px; transition: color var(--t); }
  .clear-btn:hover { color: var(--color-text-muted); }
  .laps-list { max-height: 150px; overflow-y: auto; display: flex; flex-direction: column; gap: var(--space-1); scrollbar-width: thin; scrollbar-color: var(--color-border) transparent; }
  .lap-row { display: flex; align-items: center; justify-content: space-between; padding: var(--space-2) var(--space-3); border-radius: var(--radius-md); background: var(--color-surface-offset); font-size: .875rem; animation: li 200ms cubic-bezier(0.16,1,0.3,1) both; }
  .lap-row.best { background: oklch(from var(--color-success) l c h / 0.12); }
  .lap-row.slow { background: oklch(from var(--color-error) l c h / 0.08); }
  .lap-n { color: var(--color-text-faint); font-size: .75rem; font-weight: 500; }
  .lap-t { font-variant-numeric: tabular-nums; font-weight: 600; }
  .lap-badge { font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; padding: 2px 6px; border-radius: var(--radius-full); }
  .best .lap-badge { background: oklch(from var(--color-success) l c h / 0.2); color: var(--color-success); }
  .slow .lap-badge { background: oklch(from var(--color-error) l c h / 0.15); color: var(--color-error); }
  @keyframes li { from{opacity:0;transform:translateY(-5px)} to{opacity:1;transform:none} }
</style>
</head>
<body>
<div class="card">
  <div class="header">
    <div class="logo">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 1.5"/><path d="M9.5 2.5h5"/><path d="M12 2.5v2.5"/>
      </svg>
      Stopwatch
    </div>
    <button class="theme-btn" id="tb" aria-label="Toggle theme">
      <svg id="ti" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
  <div class="display-wrap">
    <div class="time-main" id="td">00:00</div>
    <div class="time-ms" id="ms">.00</div>
    <div class="status" id="sl">Ready</div>
  </div>
  <div class="controls">
    <button class="btn btn-start" id="sb" onclick="doStart()">Start</button>
    <button class="btn btn-stop" id="rb" onclick="doStop()" disabled>Stop</button>
    <button class="btn btn-lap" id="lb" onclick="doLap()" disabled>Lap</button>
  </div>
  <div class="laps-section" id="ls">
    <div class="laps-head">
      <span class="laps-title">Laps</span>
      <button class="clear-btn" onclick="clearLaps()">Clear</button>
    </div>
    <div class="laps-list" id="ll"></div>
  </div>
</div>
<script>
(function(){
  // Theme
  const h=document.documentElement, tb=document.getElementById('tb'), ti=document.getElementById('ti');
  const sun='<circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>';
  const moon='<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
  let th=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
  h.setAttribute('data-theme',th); ti.innerHTML=th==='dark'?sun:moon;
  tb.onclick=()=>{th=th==='dark'?'light':'dark';h.setAttribute('data-theme',th);ti.innerHTML=th==='dark'?sun:moon;};

  // Stopwatch
  let t0=0,el=0,ls_=0,raf=null,on=false,laps=[];
  const td=document.getElementById('td'),ms=document.getElementById('ms'),sl=document.getElementById('sl');
  const sb=document.getElementById('sb'),rb=document.getElementById('rb'),lb=document.getElementById('lb');
  const ls=document.getElementById('ls'),ll=document.getElementById('ll');

  function p(n){return String(Math.floor(n)).padStart(2,'0');}
  function render(e){
    const s=e/1000, m=Math.floor(s/60), sc=Math.floor(s%60), cs=Math.floor((e%1000)/10);
    td.textContent=p(m)+':'+p(sc); ms.textContent='.'+p(cs);
  }
  function tick(){el=Date.now()-t0;render(el);raf=requestAnimationFrame(tick);}
  function setS(s){sl.textContent=s;sl.className='status'+(s==='Running'?' running':s==='Paused'?' paused':'');td.className='time-main'+(s==='Running'?' running':'');}

  window.doStart=function(){
    if(!on){t0=Date.now()-el;ls_=ls_||t0;on=true;sb.style.display='none';rb.disabled=false;lb.disabled=false;rb.textContent='Stop';setS('Running');tick();}
  };
  window.doStop=function(){
    if(on){cancelAnimationFrame(raf);on=false;sb.style.display='';sb.textContent='Resume';rb.textContent='Reset';lb.disabled=true;setS('Paused');}
    else{cancelAnimationFrame(raf);el=0;ls_=0;laps=[];on=false;render(0);setS('Ready');sb.style.display='';sb.textContent='Start';rb.textContent='Stop';rb.disabled=true;lb.disabled=true;renderLaps();}
  };
  window.doLap=function(){
    if(!on)return;const now=Date.now();laps.unshift(now-(ls_||t0));ls_=now;renderLaps();
  };
  window.clearLaps=function(){laps=[];renderLaps();};

  function fmtL(e){
    const s=e/1000,m=Math.floor(s/60),sc=Math.floor(s%60),cs=Math.floor((e%1000)/10);
    return (m>0?p(m)+':':'')+p(sc)+'.'+p(cs);
  }
  function renderLaps(){
    if(!laps.length){ls.classList.remove('on');ll.innerHTML='';return;}
    ls.classList.add('on');
    const mn=Math.min(...laps),mx=Math.max(...laps);
    ll.innerHTML=laps.map((l,i)=>{
      const n=laps.length-i;
      const cls=laps.length>1&&l===mn?' best':laps.length>1&&l===mx?' slow':'';
      const b=laps.length>1&&l===mn?'<span class="lap-badge">Best</span>':laps.length>1&&l===mx?'<span class="lap-badge">Slow</span>':'';
      return `<div class="lap-row${cls}"><span class="lap-n">Lap ${p(n)}</span><span class="lap-t">${fmtL(l)}</span>${b}</div>`;
    }).join('');
  }
})();
</script>
</body>
</html>
